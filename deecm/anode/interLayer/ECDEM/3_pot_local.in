# Battery simulation using pre-compacted particles from data file
# With type-based boundary conditions for SOR solver
# Metal particles (type 1) - Metal Particles
# Carbon particles (type 2) - Carbon Particles
# SE Layer (type 3) - SE Particles (Top)
# Li Source Layer (type 4) - Li Particles (Bottom)
# Wall particles (type 5) - Walls

# --- 1. INITIALIZATION ---
units           micro  # Using micro units to match the compaction script
atom_style      granular
atom_modify     map array
boundary        f f s  # Fixed(f) boundaries as in compaction script shrink(s)
newton          off

communicate     single vel yes

# Set timestep (Do not change radius update optimized for this value)
timestep        1.e-7

# --- 2. READ RESTART FILE ---
# Read the compacted configuration (Top --> Bottom) (SE single Particle Z-plane layer / Metal-Carbon Mixture / Li single paerticle z-plane layer)
read_data     dataAg/Ag_C5_fp250_1M.data

# --- 3. RE-ESTABLISH GROUPS ---
# Define groups based on particle types (Type 5 is the wall)
group  me    type  1   # Metal
group  cb    type  2   # Carbon
group  li    type  3   # Li Layer (bottom)
group  se    type  4   # SE Layer (top)

# Groups for particles affected by walls
group  ptc   type  1 2 # Types affected by walls
group  mobile type 1 2 4     # All particles that undergo integration (AM, CB, SE)

# --- 4. NEIGHBOR SETTINGS ---
neighbor        0.005 bin
neigh_modify    every 1 delay 0 check yes

# --- 5. RE-ESTABLISH MATERIAL PROPERTIES ---
variable        Eme           equal     76.e6  # Metal (Ag) [kPa] (MatWeb - Silver, Ag)
variable        vme           equal     0.37    # Metal (Ag) [-] (MatWeb - Silver, Ag)

variable        Ecb           equal     15.e6  # Carbon (AB) [kPa] (https://www.azom.com/properties.aspx?ArticleID=516)
variable        vcb           equal     0.20    # Carbon (AB) [-] (https://www.azom.com/properties.aspx?ArticleID=516)

variable        Ese           equal     22.1e6  # SE (Li6PS5Cl) [kPa] (http://dx.doi.org/10.1149/2.0061602jes)
variable        vse           equal     0.37    # SE (Li6PS5Cl) [-] (http://dx.doi.org/10.1149/2.0061602jes)

variable        Eli           equal     7.82e6  # Li (Li-metal) [kPa] (https://doi.org/10.1007/s10853-018-2971-3)
variable        vli           equal     0.381    # Li (Li-metal) [-] (https://doi.org/10.1007/s10853-018-2971-3)

variable        Eww           equal     100.e6    # Wall [kPa]
variable        vww           equal     0.4      # Wall [-]

# Material properties
fix     m1 all property/global youngsModulus peratomtype ${Eme} ${Ecb} ${Eli} ${Ese} ${Eww}
fix     m2 all property/global poissonsRatio peratomtype ${vme} ${vcb} ${vli} ${vse} ${vww}

# Coefficient of restitution matrix (5x5)
variable        cor_all       equal     0.1     # Same for all pairs
fix     m3 all property/global coefficientRestitution peratomtypepair 5 &
        ${cor_all} ${cor_all} ${cor_all} ${cor_all} ${cor_all} &
        ${cor_all} ${cor_all} ${cor_all} ${cor_all} ${cor_all} &
        ${cor_all} ${cor_all} ${cor_all} ${cor_all} ${cor_all} &
        ${cor_all} ${cor_all} ${cor_all} ${cor_all} ${cor_all} &
        ${cor_all} ${cor_all} ${cor_all} ${cor_all} ${cor_all}

# Coefficient of friction (5x5)
variable        cof_all       equal     0.1     # Same for all pairs
fix     m4 all property/global coefficientFriction peratomtypepair 5 &
        ${cof_all} ${cof_all} ${cof_all} ${cof_all} ${cof_all} &
        ${cof_all} ${cof_all} ${cof_all} ${cof_all} ${cof_all} &
        ${cof_all} ${cof_all} ${cof_all} ${cof_all} ${cof_all} &
        ${cof_all} ${cof_all} ${cof_all} ${cof_all} ${cof_all} &
        ${cof_all} ${cof_all} ${cof_all} ${cof_all} ${cof_all}

# Coefficient of rolling friction (5x5)
variable        corf_all      equal     0.1     # Same for all pairs
fix     m5 all property/global coefficientRollingFriction peratomtypepair 5 &
        ${corf_all} ${corf_all} ${corf_all} ${corf_all} ${corf_all} &
        ${corf_all} ${corf_all} ${corf_all} ${corf_all} ${corf_all} &
        ${corf_all} ${corf_all} ${corf_all} ${corf_all} ${corf_all} &
        ${corf_all} ${corf_all} ${corf_all} ${corf_all} ${corf_all} &
        ${corf_all} ${corf_all} ${corf_all} ${corf_all} ${corf_all}

# Cohesion energy density (5x5) Units (KPa) 50000 is 50,000 kPa (adopted from Davids Peel Test)
fix     m6 all property/global cohesionEnergyDensity peratomtypepair 5 &
        100000   100000  100000   10000  0 &
        100000   100000  100000   10000  0 &
        100000   100000  0        0      0 &
        10000    10000   0        0      0 &
        0        0       0        0      0

# --- 6. PAIR STYLE AND WALLS ---
pair_style gran model hertz tangential history cohesion sjkr
pair_coeff * *

# Re-establish wall boundaries (from compaction script)
fix xwalls1 ptc wall/gran model hertz tangential history primitive type 5 xplane 0.0
fix xwalls2 ptc wall/gran model hertz tangential history primitive type 5 xplane 2.5
fix ywalls1 ptc wall/gran model hertz tangential history primitive type 5 yplane 0.0
fix ywalls2 ptc wall/gran model hertz tangential history primitive type 5 yplane 2.5
fix zwalls1 ptc wall/gran model hertz tangential history primitive type 5 zplane 0.0

# --- 7. INTEGRATION ---
fix             integr mobile nve/sphere

#------------------------Output Settings---------------------------------------
# --- 8. ANALYSIS SETUP ---
variable        tarp1    equal  250                      # Fabrication pressure (MPa)
variable        F_total  equal  v_tarp1/(1.6e-4)          # Total downward force (nN)
variable        N_se     equal  count(se)                # Number of SE particles
variable        fz_se    equal  -v_F_total/v_N_se        # Per-particle target z-force (nN)

# Lock SE in x,y — only vertical (z) motion allowed
fix  se_lock_xy  se  setforce  0.0  0.0  NULL

# Maintain constant average z-force = target compressive pressure
# aveforce adjusts: fz_i → fz_i - <fz> + fz_target, preserving relative differences
fix  se_press_z  se  aveforce  NULL  NULL  v_fz_se

compute        ker    all  erotate/sphere
compute        frc    se  reduce sum fz # Force in [nN]
compute        posw   se  reduce ave z

variable       prs      equal  (f_se_press_z[3])*1.6e-4
variable       prs_res  equal  (c_frc)*1.6e-4   # Pressure (MPa) on 2.5 x 2.5 um area

# Create a per-atom variable that holds the value of prs1
variable        prs_atom atom v_prs

# Hydrostatic Stress Initializing
compute      st all stress/atom

# Bottom Li layer remains frozen (Dirichlet source)
fix  li_freeze   li  move linear 0 0 0

# FIXED Top and Bottom Layer from moving
# fix 1 se move linear 0 0 0  # Top Layer
# fix 2 li move linear 0 0 0  # Bottom Layer

# --- 9.0. ELECTROCHEMICAL COMPUTATIONS ---

# Initialize lithium content (Li/Metal molar ratio) - for AM & CB particles
fix             li_content ptc property/atom/lithium_content initial 0.0 target 1.0 max 1.0

# Calculate equilibrium potential - for AM and CB particles
fix             eq_pot all equilibrium_potential temperature 298.15 AM_material Ag CB_material C &
                x_max_AM 1.0 x_max_CB 1.0 AM_type 1 CB_type 2 LM_type 3

# SOR solver for potential with type-based boundary conditions (cathode anode) condutivity (AM, SE, CC) (1 A/m2 = 0.1 mA/cm2)
fix pot all potential/sor omega 1.0 max_iter 10 temperature 298.15 &
    AM_type 1 CB_type 2 LM_type 3 SE_type 4 &
    area 6.25e-12 i_app 1.0 &
    sigma_el 6.29e7 131.0 0.0 1.08e7 &
    sigma_ed 6.29e7 131.0 1.08e7 0.0 &
    BC_LM_el potential  0.0 &
    BC_LM_ed potential  0.0 &
    BC_SE_ed current    10.0 &
    BC_SE_el current   -10.0

# IMPLICIT diffusion (D_LM = 1.0e-14 for Anode, 0 for anode free)
fix  diff all lithium_diffusion_implicit AM_type 1 CB_type 2 LM_type 3 &
     diffusion_dt 0.0005 update_every 1 max_iter 500 tolerance 1.0e-2 &
     c_li_max_LM 77101.002 c_li_max_AM 85155.85 c_li_max_CB 27776.39 V_exp_max_AM 10.291 &
     D_AM 1.0e-10 D_LM 0 &
     Omega_Li_AM 1.0602e-05 Omega_Li_CB 4.1418e-06 Omega_Li_LM 12.97e-06

# Radius expansion for AM & CB particles (optional - Omega_Li_CB is smaller b/c saying volume doesnt change much with Li content )
fix             radexp all radius_expansion AM_type 1 CB_type 2 update_every 1 &
                Omega_Li_AM 1.0602e-05 Omega_Li_CB 4.1418e-6

# --- 11. TIMING ---
# 900 s real time / 0.001 s per solve = 900,000 solves
# 900,000 solves * 10 DEM steps per solve = 9,000,000 total DEM steps
variable  rest_time      equal 0.1            # Rest time in seconds (Note Scale: Sim(h)/0.5mm * 8mm = Real (h))
variable  diff_dt        equal 0.0005
variable  dem_steps_per  equal 1
variable  run_steps      equal round(${rest_time}/${diff_dt})*${dem_steps_per}
variable  dump_freq      equal round(${run_steps}/100)
variable  thermo_freq    equal round(${run_steps}/200)

# Create a per-atom variable that holds the value of f_diff[3] = total diffusion time (s)
variable        tdt_atom atom f_diff[3]

# Thermo output
thermo_style custom step atoms ke v_prs v_prs_res c_posw f_diff[1] f_diff[2] f_diff[3]
# f_diff[1] = last Jacobi iteration count
# f_diff[2] = last residual
# f_diff[3] = total diffusion time (s)
thermo          ${thermo_freq}
thermo_modify   lost ignore norm no

# Dump for visualization
dump            dmp_batt all custom ${dump_freq} post/postp/CB_fp250_anodefree_0d1s_v4/battery_*.txt id type x y z vx vy vz fx fy fz omegax omegay omegaz radius &
                f_electrolytePotential f_electronicPotential f_currentElectrolyte f_currentElectronic &
                f_hydrostaticStress f_lithiumContent f_lithiumConcentration f_lithiumMols f_equilibriumPotential f_diffusionCoefficient v_prs_atom v_tdt_atom

# 4. Run EC
run             ${run_steps}