# Run with "mpirun -np 12 lmp -in comp.in"

##################################### SIMULATION SETTINGS ###################################################

atom_style      sphere 1
atom_modify     map array
boundary        f f s
comm_modify     vel yes
units           si
newton          off
neighbor        1.0e-6 bin
neigh_modify    every 1 delay 0 check yes
processors      * * 1

############################## SIMULATION BOUNDING BOX AND INSERT PARTICLES #################################

read_data data/mdl.data

#################################### ADD DIE AND ATOM PARAMETERIZATION ######################################

compute     rad         all     property/atom radius    # Particle Radius [m]
compute     avgRad      all     reduce ave c_rad        # Average Particle Radius [m]
variable    avgRadv     equal   c_avgRad
variable    dieR        equal   20.0e-6                 # Die Radius [m]
variable    dieH        equal   20.0e-6                 # Die Initial Height [m]
variable    den         equal   5000                    # Density of SE [kg/m3]
variable    velc        equal   1.0                     # Plunger Velocity [m/s]
variable    tarp        equal   5e6                     # Plunger Pressure [Pa]

############################## PARTICLE MATERIAL PROPERTIES AND FORCE MODEL ##################################
run 0
pair_style granular

variable Ese      equal 0.221e9                                         # Elastic Modulus [Pa]
variable vse      equal 0.37                                            # Poissons Ratio
variable Yse      equal 0.01e6                                          # Yield Strength [Pa]
variable SEse     equal 900                                             # Effective surface energy SE [J/m2]
variable SEww     equal 0                                               # Effective surface energy Wall [J/m2]
variable psi_b    equal 0.125                                           # Critical confinement ratio [-]
variable damp     equal 1.0e4*${den}*${avgRadv}*${avgRadv}*${velc}      # Normal direction damping coefficient [kg/s]

variable kt         equal 2/7*${Ese}*${avgRadv}                         # Tangential stiffness coefficient [N/m]
variable kt_wall    equal 2/7*${Ese}*${avgRadv}                         # Tangential stiffness coefficient [N/m]
variable xgammat    equal 1.0                                           # Dimensionless multiplier for normal damping
variable mu_t       equal 0.3                                           # Tangential friction coefficient SE
variable mu_t_ww    equal 0.1                                           # Tangential friction coefficient Wall

variable mu_roll     equal 1.0                                              # Rolling friction coefficient SE/wall
variable k_roll      equal 2.25*${mu_roll}*${mu_roll}*${Ese}*${avgRadv}     # Rolling stiffness coefficient [N/m]
variable gamma_roll  equal ${damp}                                          # Rolling direction damping coefficient [kg/s]

pair_coeff * * mdr ${Ese} ${vse} ${Yse} ${SEse} ${psi_b} ${damp} &
    damping mdr 1 &
    tangential linear_history ${kt} ${xgammat} ${mu_t} &
    rolling sds ${k_roll} ${gamma_roll} ${mu_roll}

######################################### DYNAMIC TIMESTEP ###################################################
#
# Use fix dt/reset to automatically adapt the timestep based on particle kinematics.
# This eliminates the need for manual timestep assignment between phases.
#
# Parameters:
#   N       = 10        : re-evaluate dt every 10 steps
#   dt_min  = 1.0e-13 s : floor (prevents dt from collapsing to zero)
#   dt_max  = 5.0e-11 s : ceiling (matches original Phase 1 timestep)
#   xmax_dt             : max displacement any atom may travel per step;
#                         controls the CFL-like stability criterion.
#                         Tune this: smaller = more conservative / stable,
#                         larger = faster but risk instability.
#
# Rayleigh critical timestep estimate (for reference):
#   G       = E / (2*(1+nu)) ~ 8.07e9 Pa
#   dt_R    = pi*R*sqrt(rho/G) / (0.1631*nu + 0.8766)
#   For R~5um: dt_R ~ 1.3e-8 s  =>  dt_max << dt_R, so we are well within stability.
#
#############################################################################################################

variable dt_max     equal 5.0e-11
variable dt_min     equal 1.0e-14
variable xmax_dt    equal 0.0005*${avgRadv}         # 0.05% of avg particle radius per step

timestep ${dt_max}                                  # Seed value; overridden by fix dt/reset

# N = 1 : re-evaluate EVERY step.  fix dt/reset is reactive (it measures
#          v_max AFTER the step), so checking every 10th step leaves a
#          window where a force spike can drive particles into unrecoverable
#          overlap before dt is reduced.  N=1 closes that window.

fix dtfix all dt/reset 1 ${dt_min} ${dt_max} ${xmax_dt} units box

######################################### ADD DIE AND PUNCH WALLS ############################################
#
# KEY CHANGE: Wall displacement is now expressed in terms of the LAMMPS "time"
# thermo keyword, which returns cumulative simulation time.  Unlike "step*dt",
# "time" correctly accumulates variable-width timesteps:
#
#   time = sum_{i=0}^{N} dt_i
#
# This decouples the wall trajectory from the timestep entirely.
#
#############################################################################################################

# Initial punch displacements (zero during settling / initialisation)
variable disp_upper      equal 0.0
variable disp_lower      equal 0.0

variable wall_mdr string "granular mdr ${Ese} ${vse} ${Yse} ${SEww} ${psi_b} ${damp} &
    damping mdr 1 &
    tangential linear_history ${kt_wall} ${xgammat} ${mu_t_ww} &
    rolling sds ${k_roll} ${gamma_roll} ${mu_roll}"

variable dieHeight2 equal 2*${dieH}

region lowerPunch plane 0 0 0 0 0 1 side in units box move NULL NULL v_disp_lower units box
region upperPunch plane 0 0 ${dieH} 0 0 -1 side in move NULL NULL v_disp_upper units box
region die cylinder z 0 0 ${dieR} 0 ${dieHeight2} side in units box

fix lowerPunch all wall/gran/region ${wall_mdr} region lowerPunch contacts
fix upperPunch all wall/gran/region ${wall_mdr} region upperPunch contacts
fix die all wall/gran/region ${wall_mdr} region die contacts

# Force on Plunger [N]
compute     frc     all     reduce sum f_upperPunch[4]
variable    frcv    equal   c_frc

run 0

#------------------------Pressure Calculation------------------------------------------------------

variable    area        equal   PI*${dieR}*${dieR}
variable    prs         equal   -v_frcv/v_area
variable    prs_atom    atom    v_prs

#------------------------Porosity Calculation------------------------------------------------------

variable    posw equal ${dieH}+v_disp_upper

variable    vol_atom atom (4.0/3.0)*PI*c_rad*c_rad*c_rad
compute     vol_se all reduce sum v_vol_atom

variable    Vbox   equal v_area*v_posw
variable    Vsolid equal c_vol_se
variable    poro   equal 1.0-(v_Vsolid/v_Vbox)
variable    poro_atom atom v_poro

##################################### INTEGRATION #################################################

fix 1 all nve/sphere

########################################### SCREEN OUTPUT  ####################################################

compute       1 all erotate/sphere
thermo_style  custom dt step atoms ke vol v_prs v_poro v_posw
thermo        500
thermo_modify lost ignore norm no

##################################### SET UP DUMP OUTPUTS  ####################################################

dump 1 all custom 2500 post/mdl50.dump id type mass diameter x y z vx vy vz fx fy fz v_poro_atom v_prs_atom

############################################## RUN SIMULATION #################################################

# ============================================================================
#   PHASE 1 — COMPRESSION (upper punch moves DOWN)
# ============================================================================
#
#   Displacement = -velc * (time - t0_compress)
#
#   "time" is the cumulative simulation clock.  $(time) is evaluated ONCE when
#   this line is parsed (immediate substitution), giving us the constant t0.
#   "time" inside the equal-style variable is re-evaluated every step.
#
#   The loop runs in fixed-step chunks; fix dt/reset handles the actual
#   timestep sizing.  Chunk size is a trade-off:
#     - Smaller => more frequent pressure checks, tighter control
#     - Larger  => less overhead from LAMMPS run startup per chunk
#   25 000 steps is a reasonable default; adjust to taste.
# ============================================================================

variable t0_compress equal $(time)
variable disp_upper  delete
variable disp_upper  equal -${velc}*(time-${t0_compress})

# Start (z=20), End (z = 9.0), dt = 5.e-11 [s], v = 10.0 [m/s]
run 220000

# Check every 0.25
label compress_loop
    if "${prs} >= ${tarp}" then "jump SELF release_start"
    run 5000
jump SELF compress_loop

# ============================================================================
#   PHASE 2 — RELEASE (upper punch moves UP)
# ============================================================================
#
#   At the moment we reach target pressure, freeze the maximum stroke and
#   reverse direction:
#
#     stroke_max   = velc * (t_release - t0_compress)   [m]  (positive)
#     disp_upper   = -(stroke_max - velc*(time - t_release))
#
#   As time advances past t_release the displacement magnitude shrinks,
#   i.e. the punch retracts.
# ============================================================================

label release_start

variable t0_release  equal  $(time)
variable stroke_max  equal  ${velc}*(${t0_release}-${t0_compress})

variable disp_upper  delete
variable disp_upper  equal  -(${stroke_max}-${velc}*(time-${t0_release}))

label release_loop
    if "${prs} <= 1" then "jump SELF rest_start"
    run 5000
jump SELF release_loop

# ============================================================================
#   PHASE 3 — REST (let the system equilibrate)
# ============================================================================

label rest_start
run 5000

############### WRITE OUTPUT ###############

write_data data/comp50.data