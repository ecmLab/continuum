LIGGGHTS (Version LIGGGHTS-PUBLIC-FIBERS 3.8.0, compiled 2024-01-30-15:28:26 by jchits, git commit 9ac9b48460642a344aa2f18bbbb435c5a3e8fde6)
### Material Independent Properties
#variable particle_diameter             equal 0.0171    	                # particles diameter in meters VULCAN
variable particle_diameter             equal 0.0205    	                # particles diameter in meters C-65
#variable particle_diameter             equal 0.0228    	                # particles diameter in meters KB
variable bond_out_diameter             equal ${particle_diameter}    	# fiber outer diameter in meters
variable bond_out_diameter             equal 0.0205    	
variable bond_in_diameter              equal 0.0                        # fiber inner diameter in meters
variable bond_damp_type                equal 1                          # Use Yu Guo Damping
variable bond_damp_val                 equal 0.1      					# NA
variable fiber_contact_youngs_modulus  equal 0.185e6      				# Pa
variable bond_youngs_modulus           equal 0.185e6      				# Pa
variable particle_poissons_ratio       equal 0.3        			 	# NA
variable coef_res_pp                   equal 0.500      				# particle-particle coefficient of restitution
variable coef_res_pw                   equal 0.500      				# particle-wall coefficient of restitution
variable coef_res_ww                   equal 0.500      				# wall-wall coefficient of restitution
variable coef_fri_pp                   equal 0.500      				# particle-particle coefficient of friction
variable coef_fri_pw                   equal 0.500      				# particle-wall coefficient of friction
variable coef_fri_ww                   equal 0.500      				# wall-wall coefficient of friction


### Material Dependent Properties
variable bond_shear_modulus            equal ${bond_youngs_modulus}/(2.0*(1.0+${particle_poissons_ratio}))
variable bond_shear_modulus            equal 185000/(2.0*(1.0+${particle_poissons_ratio}))
variable bond_shear_modulus            equal 185000/(2.0*(1.0+0.3))
variable bond_out_per                  equal ${bond_out_diameter}/${particle_diameter}
variable bond_out_per                  equal 0.0205/${particle_diameter}
variable bond_out_per                  equal 0.0205/0.0205
variable bond_in_per                   equal ${bond_in_diameter}/${particle_diameter}
variable bond_in_per                   equal 0/${particle_diameter}
variable bond_in_per                   equal 0/0.0205

atom_style 	hybrid granular bond/gran n_bondtypes 1 bonds_per_atom 12
atom_modify	map array
boundary	f f f	#periodic in z
newton		off

communicate	single vel yes

units		micro

region		reg block -0.05 3.19 -0.05 3.19 -0.7 3.05 units box
create_box	2 reg
Created orthogonal box = (-0.05 -0.05 -0.7) to (3.19 3.19 3.05)
  2 by 2 by 3 MPI processor grid

#processors     2 2 1
neighbor	    0.01 bin
neigh_modify	delay 0


#Material properties required for new pair styles

fix 		m1 all property/global youngsModulus peratomtype 0.185e6 185e6
fix 		m2 all property/global poissonsRatio peratomtype 0.3 0.3
fix 		m3 all property/global coefficientRestitution peratomtypepair 2 0.1 0.1 0.1 0.1
fix 		m4 all property/global coefficientFriction peratomtypepair 2 0.5 0.5 0.5 0.5
fix 		m5 all property/global coefficientRollingFriction peratomtypepair 2 0.5 0.5 0.5 0.5

pair_style gran model hertz tangential history
bond_style gran
WARNING: Bond granular: This is a beta version - be careful! (../bond_gran.cpp:106)
pair_coeff  * *
bond_coeff 	1 ${bond_out_per} ${bond_in_per} ${bond_youngs_modulus} ${bond_shear_modulus} ${bond_damp_type} ${bond_damp_val} 1 1.0e32 1.0e32
bond_coeff 	1 1 ${bond_in_per} ${bond_youngs_modulus} ${bond_shear_modulus} ${bond_damp_type} ${bond_damp_val} 1 1.0e32 1.0e32
bond_coeff 	1 1 0 ${bond_youngs_modulus} ${bond_shear_modulus} ${bond_damp_type} ${bond_damp_val} 1 1.0e32 1.0e32
bond_coeff 	1 1 0 185000 ${bond_shear_modulus} ${bond_damp_type} ${bond_damp_val} 1 1.0e32 1.0e32
bond_coeff 	1 1 0 185000 71153.8461538462 ${bond_damp_type} ${bond_damp_val} 1 1.0e32 1.0e32
bond_coeff 	1 1 0 185000 71153.8461538462 1 ${bond_damp_val} 1 1.0e32 1.0e32
bond_coeff 	1 1 0 185000 71153.8461538462 1 0.1 1 1.0e32 1.0e32

timestep	0.00001

group ptc  type  1
0 atoms in group ptc
group gst  type  2
0 atoms in group gst

fix 	sinwa ptc mesh/surface file Part2.stl type 2 scale 0.001 curvature_tolerant yes
fix 	wall ptc wall/gran model hertz tangential history rolling_friction epsd2 mesh n_meshes 1 meshes sinwa
WARNING: 
	The contact model you specified is not located in any whitelist.
	Because of this the model will be run in an unoptimized version (increasing runtime by up to 20%).
	In order to optimize this model you have the following options:
		(i)  Run the genAutoExamplesWhitelist.sh script in your LIGGGHTS(R) source folder to automatically parse the input script
		(ii) Add the model combination by hand to your style_contact_model_user.whitelist that can be found in your LIGGGHTS(R) source folder
	If you perform one of the steps above LIGGGHTS(R) needs to be recompiled to generate the optimized code.

 (../contact_models.h:364)

fix     zwalls1  ptc wall/gran model hertz tangential history primitive type 1 zplane -0.7
fix     zwalls2  ptc wall/gran model hertz tangential history primitive type 1 zplane 3
fix     xwalls1  ptc wall/gran model hertz tangential history primitive type 1 xplane 0
fix     xwalls2  ptc wall/gran model hertz tangential history primitive type 1 xplane 3.14
fix     ywalls1  ptc wall/gran model hertz tangential history primitive type 1 yplane 0
fix     ywalls2  ptc wall/gran model hertz tangential history primitive type 1 yplane 3.14

region  bc block 0 3.14 0 3.14 0 2.9 units box
#fix	  pts1 all particletemplate/multiplespheres 67867967 atom_type 1 density constant 2500 nspheres 110 ntry 500000 spheres file Data/positions_Vulcan.txt scale 1 bonded yes
fix	  pts1 all particletemplate/multiplespheres 67867967 atom_type 1 density constant 2500 nspheres 110 ntry 500000 spheres file Data/positions_C-65.txt scale 1 bonded yes
Finished calculating properties of template
   mass = 1.251171e+00, radius of bounding sphere = 2.070033e-01, radius of equivalent sphere = 4.925263e-02
   center of mass = 0.000000e+00, 0.000000e+00, 0.000000e+00
   center of bounding sphere in global coords = -5.896564e-02, -1.464208e-02, -7.552388e-06
#fix	  pts1 all particletemplate/multiplespheres 67867967 atom_type 1 density constant 2500 nspheres 183 ntry 500000 spheres file Data/positions_KB.txt scale 1 bonded yes

fix   pdd1 ptc particledistribution/discrete 15485867 1 pts1 1.0
fix   ins ptc insert/pack seed 32452843 distributiontemplate pdd1 maxattempt 1000 insert_every 2000 												overlapcheck yes orientation random all_in yes 												vel constant 0.0 0.0 0.0 region bc particles_in_region 925 												ntry_mc 500000

fix     integr all nve/sphere

compute        ker  all   erotate/sphere                  # Compute the rotational kinetic energy of all particles
compute        frc  gst   reduce sum fz                   # Total pressure on ghost particles
variable       prs  equal  (c_frc)/(1000*3.14*3.14)    # Pressure in unit of MPa
# Print info to screen, include step, total atom number, kinetic nergy, compute_1(Rotational energy), volume
thermo_style    custom step atoms numbonds cpu cpuremain ke v_prs
thermo          10000                              # Print thermodynamics every 500 stimesteps
thermo_modify   lost ignore norm no
compute_modify	thermo_temp dynamic yes
WARNING: Changing thermo_temp compute object. This object is deprecated and will be removed in the future. (../compute.cpp:161)

dump			dmp all custom 100000 post_C65/dump*.liggghts id type x y z vx vy vz fx fy fz omegax omegay omegaz radius mass

variable bond_skin equal 1.00000001*${particle_diameter}
variable bond_skin equal 1.00000001*0.0205
run 1
